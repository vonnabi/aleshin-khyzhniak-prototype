# Скопіюй у .env (або пропиши у cPanel → Setup Python App → Environment variables)

# Секретний ключ Django. ОБОВʼЯЗКОВО згенеруй свій:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace-me-with-your-own-generated-key

# На бойовому сервері тримай вимкненим.
DJANGO_DEBUG=false

# Твої домени через кому (без http://). Поки не знаєш — лиши *.
DJANGO_ALLOWED_HOSTS=*
